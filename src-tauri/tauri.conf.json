{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NekoBeat",
  "version": "0.2.0",
  "identifier": "com.nishal21.nekobeat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "nekobeat",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "gstreamer/**/*",
      "bin/yt-dlp.exe"
    ],
    "externalBin": [
      "binaries/spotiflac-cli"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gist.githubusercontent.com/nishal21/9e13884354b4b3c11dac82a7356b81dd/raw/ab394352fba9acf565932f092f10dd79b538d568/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEM0RDMjE2RkI1QkM5QzUKUldURnlWdjdGc0k5UFh4cXNSSlZvdGM5dTcyaEdsY0hQZlZPMGFHZEF6U2YzdGhTbTkvQzUxbzkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}